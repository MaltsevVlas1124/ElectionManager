<Window x:Class="ElectionManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система електронного голосування" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/Logo.png">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Система">
                <MenuItem Header="_Імпорт бази даних" Click="MenuImportDb_Click"/>
                <MenuItem Header="_Експорт бази даних" Click="MenuExportDb_Click"/>
                <Separator/>
                <MenuItem Header="_Вихід з програми" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Профіль">
                <MenuItem Header="Змінити _акаунт" Click="MenuChangeAccount_Click"/>
            </MenuItem>
            <MenuItem Header="_Інформація">
                <MenuItem Header="Про _застосунок" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Padding="3">
                <ToolBar.Resources>
                    <Style x:Key="StandardBtnStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="BorderBrush" Value="#C0C0C0"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </ToolBar.Resources>

                <Button Content="Змінити акаунт"
                        Style="{StaticResource StandardBtnStyle}"
                        ToolTip="Вийти та увійти під іншим користувачем"
                        Click="MenuChangeAccount_Click"/>
                
                <Button Content="Імпортувати базу"
                        Style="{StaticResource StandardBtnStyle}"
                        ToolTip="Імпортувати дані з існуючого JSON-файлу"
                        Click="MenuImportDb_Click"/>

                <Button Content="Експортувати базу"
                        Style="{StaticResource StandardBtnStyle}"
                        ToolTip="Експортувати поточну базу в JSON-файл"
                        Click="MenuExportDb_Click"/>

                <Separator Margin="2,0"/>

                <Button Content="Про програму"
                        Style="{StaticResource StandardBtnStyle}"
                        ToolTip="Переглянути інформацію про розробника"
                        Click="MenuAbout_Click"/>


            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusRole"
                           FontWeight="Bold"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Користувач: "/>
                    <TextBlock x:Name="TxtStatusBarUser"
                               Text="Не авторизовано"
                               Foreground="DarkRed"
                               FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Перелік голосувань"
                      Grid.Column="0" Margin="0,0,5,0" Foreground="Gray">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,10">
                        <TextBlock Text="Пошук за назвою:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Black"/>
                        <TextBox x:Name="TxtSearch" Width="200" TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="ElectionsGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="ElectionsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Назва кампанії"
                                                Binding="{Binding Title}" Width="*"/>

                            <DataGridTextColumn Header="Старт"
                                                Binding="{Binding StartDate, StringFormat=dd.MM.yyyy HH:mm}"
                                                Width="115"/>

                            <DataGridTextColumn Header="Завершення"
                                                Binding="{Binding EndDate, StringFormat=dd.MM.yyyy HH:mm}"
                                                Width="115"/>
                            <DataGridCheckBoxColumn Header="Статус"
                                                    Binding="{Binding IsActive, Mode=OneWay}"
                                                    Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnAddElection"
                                Content="Додати" Width="70"
                                Margin="0,0,5,0" Click="BtnAddElection_Click"/>
                        <Button x:Name="BtnEditElection"
                                Content="Редагувати" Width="80"
                                Margin="0,0,5,0" IsEnabled="False"
                                Click="BtnEditElection_Click"/>
                        <Button x:Name="BtnDeleteElection"
                                Content="Видалити" Width="70"
                                Margin="0,0,5,0" IsEnabled="False"
                                Click="BtnDeleteElection_Click"/>
                        <Button x:Name="BtnShowResults"
                                Content="Результати" Width="80"
                                IsEnabled="False" Click="BtnShowResults_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox x:Name="GrpElectionDetails"
                      Header="Варіанти голосування"
                      Grid.Column="1" IsEnabled="False" Foreground="Gray">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="5,5,5,10">
                        <TextBlock x:Name="TxtElectionTitle"
                                   Text="Оберіть голосування зліва"
                                   FontWeight="Bold" FontSize="15"
                                   TextWrapping="Wrap" Foreground="Black"/>
                        <TextBlock x:Name="TxtElectionDates"
                                   Text="" Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid x:Name="CandidatesGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"
                                                Binding="{Binding Id}"
                                                Width="35"/>
                            <DataGridTextColumn Header="Кандидат"
                                                Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Інформація"
                                                Binding="{Binding Information}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#E8F4F8"
                            BorderBrush="#BEE1EB" BorderThickness="1"
                            CornerRadius="3" Padding="10" Margin="0,8,0,0">
                        <Button x:Name="BtnVote"
                                Content="Віддати голос"
                                Width="150" Height="30"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                Click="BtnVote_Click"/>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>