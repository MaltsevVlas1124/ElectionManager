<Window x:Class="ElectionManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система електронного голосування" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Система">
                <MenuItem Header="_Вихід з програми" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Профіль">
                <MenuItem Header="_Авторизація / Реєстрація" Click="BtnChangeAccount_Click"/>
            </MenuItem>
            <MenuItem Header="_Інформація">
                <MenuItem Header="_Про застосунок" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Увійти" ToolTip="Авторизація" Click="BtnChangeAccount_Click"/>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Поточний користувач: "/>
                    <TextBlock x:Name="TxtStatusBarUser" Text="Не авторизовано" Foreground="DarkRed" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Перелік голосувань" Grid.Column="0" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ElectionsGrid" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="ElectionsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Назва кампанії" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Старт" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy HH:mm}" Width="110" />
                            <DataGridCheckBoxColumn Header="Активні" Binding="{Binding IsActive, Mode=OneWay}" Width="60" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Додати" Width="70" Margin="0,0,5,0" Click="BtnAddElection_Click"/>
                        <Button x:Name="BtnEditElection" Content="Редагувати" Width="80" Margin="0,0,5,0" Click="BtnEditElection_Click" IsEnabled="False"/>
                        <Button x:Name="BtnShowResults" Content="Результати" Width="80" Click="BtnShowResults_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox x:Name="GrpElectionDetails" Header="Кандидати" Grid.Column="1" IsEnabled="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="5,5,5,10">
                        <TextBlock x:Name="TxtElectionTitle" Text="Оберіть голосування зліва" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtElectionDates" Text="" Foreground="Gray" Margin="0,5,0,0"/>
                    </StackPanel>

                    <DataGrid x:Name="CandidatesGrid" Grid.Row="1" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              LoadingRow="CandidatesGrid_LoadingRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}" Width="40" />
                            <DataGridTextColumn Header="Кандидат" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="Інформація" Binding="{Binding Information}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#E8F4F8" BorderBrush="#BEE1EB" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnVote" Content="Віддати голос" Width="120" Height="30" FontWeight="Bold" Click="BtnVote_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>