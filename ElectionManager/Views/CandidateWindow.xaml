<Window x:Class="ElectionManager.Views.CandidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кандидат" Height="200" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="/Resources/Logo.png">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Кандидат:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox x:Name="TxtFullName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" ToolTip="ПІБ або назва партії"/>

        <TextBlock Text="Інформація:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox x:Name="TxtInfo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Зберегти" Width="80" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Скасувати" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>