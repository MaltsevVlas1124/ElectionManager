<Window x:Class="ElectionManager.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизація" Height="250" Width="320"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/Logo.png">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Введіть дані для входу або реєстрації" 
                   Foreground="Gray" Margin="0,0,0,15"
                   Background="Transparent" MouseDown="Secret_MouseDown"/>
        <TextBlock x:Name="TxtSecretHint" Grid.Row="0" Grid.ColumnSpan="2"
                   Foreground="DarkOrange" FontSize="8" 
                   HorizontalAlignment="Center" Margin="0,18,0,8" 
                   Visibility="Collapsed"/>

        <TextBlock Text="Логін:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <TextBox x:Name="TxtLogin" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"/>

        <TextBlock Text="Пароль:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,12"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"/>

        <StackPanel x:Name="PanelSecretAdmin" Grid.Row="3" Grid.ColumnSpan="2" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="Введіть ключ адміністратора:" Foreground="DarkRed" FontSize="11" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtAdminCode" FontSize="13" Background="#FFF0F0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Увійти/Зареєструватися" Width="150" Margin="0,0,10,0" Click="BtnLogin_Click"/>
            <Button Content="Скасувати" Width="90" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>