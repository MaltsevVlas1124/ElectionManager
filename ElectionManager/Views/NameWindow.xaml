<Window x:Class="ElectionManager.Views.NameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вітаємо у системі" Height="200" Width="360"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/Logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Вас зареєстровано у системі."
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1"
                   Text="Введіть ваше ім'я або нікнейм. Змінити його буде неможливо."
                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <TextBox x:Name="TxtFullName" Grid.Row="2"
                 VerticalAlignment="Top" Margin="0,0,0,15"
                 FontSize="13"/>

        <Button Grid.Row="3" Content="Підтвердити"
                Width="120" HorizontalAlignment="Right"
                Click="BtnConfirm_Click"/>
    </Grid>
</Window>