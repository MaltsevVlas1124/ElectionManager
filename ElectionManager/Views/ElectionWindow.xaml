<Window x:Class="ElectionManager.Views.ElectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Виборча кампанія" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/Logo.png">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Назва:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox x:Name="TxtTitle" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Text="Тип:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox x:Name="CmbType" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
            <ComboBoxItem Content="Мажоритарні (Один переможець)"/>
            <ComboBoxItem Content="Пропорційні (Відсотки)"/>
        </ComboBox>

        <TextBlock Text="Початок:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <DatePicker x:Name="DpStart" Width="120" Margin="0,0,10,0"
                        DisplayDateStart="{x:Static sys:DateTime.Today}"
                        SelectedDateChanged="DpStart_SelectedDateChanged"/>
            <TextBlock Text="Час (ГГ:ХХ):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="TxtStartTime" Width="50" Text="08:00" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Завершення:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <DatePicker x:Name="DpEnd" Width="120" Margin="0,0,10,0"
                        DisplayDateStart="{Binding SelectedDate, ElementName=DpStart}"/>
            <TextBlock Text="Час (ГГ:ХХ):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="TxtEndTime" Width="50" Text="20:00" VerticalAlignment="Center"/>
        </StackPanel>

        <GroupBox Header="Кандидати" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="LstCandidates" Grid.Column="0" DisplayMemberPath="FullName" Margin="0,0,5,0"/>
                <StackPanel Grid.Column="1">
                    <Button Content="Додати" Width="80" Margin="0,0,0,5" Click="BtnAddCandidate_Click"/>
                    <Button Content="Редагувати" Width="80" Margin="0,0,0,5" Click="BtnEditCandidate_Click"/>
                    <Button Content="Видалити" Width="80" Click="BtnRemoveCandidate_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Зберегти" Width="100" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Скасувати" Width="100" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>