<Window x:Class="ElectionManager.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Про застосунок" Height="260" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="/Resources/Logo.png">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="114*"/>
            <ColumnDefinition Width="11*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,15,0" Height="150" VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="Фотка десь загубилась" TextAlignment="Center" VerticalAlignment="Center" Foreground="Gray" TextWrapping="Wrap"/>
                <Image Source="/Resources/Photo.png" Stretch="UniformToFill"/>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <TextBlock Text="Система електронного голосування" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <TextBlock Text="Курсова робота з дисципліни" Margin="0,0,0,5"/>
            <TextBlock Text="«Об'єктно-орієнтоване програмування»" Margin="0,0,0,15"/>
            <TextBlock Text="Виконав:" FontWeight="Bold"/>
            <TextBlock Text="Здобувач вищої освіти" Margin="0,0,0,2"/>
            <TextBlock Text="Групи КС-24" Margin="0,0,0,2"/>
            <TextBlock Text="Мальцев Влас Євгенійович" Margin="0,0,0,15"/>
            <Button Content="Закрити" Width="80" HorizontalAlignment="Right" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>